<?xml version="1.0" encoding="utf-8"?>
<!-- coverlet.collector'ın ("XPlat Code Coverage") çıktısını SonarCloud'un
     okuyabildiği OpenCover formatında üretir. -->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>opencover</Format>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
